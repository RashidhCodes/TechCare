<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/light_bg">

    <!-- HEADER -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:background="@color/primary"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="15dp">

        <TextView
            android:id="@+id/btnBack"
            android:text="←"
            android:textSize="20sp"
            android:textColor="@color/white"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <TextView
            android:text="Repair Request"
            android:textSize="16sp"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"/>

        <TextView
            android:text=""
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

    </LinearLayout>

    <!-- SCROLLABLE CONTENT -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="15dp">

            <!-- STEP INDICATOR -->
            <TextView
                android:text="PROGRESS STEP 1 OF 2"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="@color/accent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="15dp"/>

            <!-- DEVICE LABEL -->
            <TextView
                android:text="Hardware Device Target"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/text_dark"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="5dp"/>

            <!-- DEVICE SPINNER -->
            <Spinner
                android:id="@+id/spinnerDevice"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/input_bg"
                android:layout_marginBottom="15dp"
                android:padding="5dp"/>

            <!-- FAULT LABEL -->
            <TextView
                android:text="Detailed Fault Description"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/text_dark"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="5dp"/>

            <!-- FAULT INPUT -->
            <EditText
                android:id="@+id/etFault"
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:hint="Describe the issue with your device..."
                android:inputType="textMultiLine"
                android:gravity="top"
                android:background="@drawable/input_bg"
                android:layout_marginBottom="15dp"/>

            <!-- LOGISTICS LABEL -->
            <TextView
                android:text="Fulfillment Logistics"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/text_dark"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"/>

            <!-- RADIO BUTTONS -->
            <RadioGroup
                android:id="@+id/radioLogistics"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="15dp">

                <RadioButton
                    android:id="@+id/rbPickup"
                    android:text="Secure Home Pickup"
                    android:textSize="13sp"
                    android:textColor="@color/text_dark"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"/>

                <RadioButton
                    android:id="@+id/rbDropoff"
                    android:text="Drop-off at Service Depot"
                    android:textSize="13sp"
                    android:textColor="@color/text_dark"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

            </RadioGroup>

            <!-- DATE LABEL -->
            <TextView
                android:text="Appointment Date"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/text_dark"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="5dp"/>

            <!-- DATE INPUT -->
            <EditText
                android:id="@+id/etDate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Tap to select date"
                android:focusable="false"
                android:clickable="true"
                android:background="@drawable/input_bg"
                android:layout_marginBottom="25dp"/>

            <!-- NEXT BUTTON -->
            <Button
                android:id="@+id/btnNext"
                android:text="REVIEW REQUEST"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:backgroundTint="@color/primary"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:padding="12dp"/>

        </LinearLayout>
    </ScrollView>

</LinearLayout>